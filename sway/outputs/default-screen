### Output configuration
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

# Default wallpaper
output * bg $background fill

# DisplaysConfiguration
bindsym $mod+f2 output eDP-1 pos 600 0 res 1366x768, output HDMI-A-2 pos 0 0 res 800x600
output HDMI-A-2 pos 1366,0 res 1360x768
output eDP-1 pos 0,0 res 1366x768

# Workspaces
workspace 1 output eDP-1
workspace 2 output eDP-1
workspace 3 output eDP-1
workspace 4 output HDMI-A-2
workspace 5 output HDMI-A-2
workspace 6 output HDMI-A-2
workspace 7 output HDMI-A-2
workspace 8 output HDMI-A-2
workspace 9 output HDMI-A-2
