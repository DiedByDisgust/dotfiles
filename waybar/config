{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "height": 36, // Waybar height (to be removed for auto height)
    // Archived modules
    // "custom/gpu", "bluetooth",  "custom/weather", "temperature", "sway/window"
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock", "custom/weather"],
    "modules-right": [ "pulseaudio", "bluetooth", "network", "battery", "tray"],
    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",


            "urgent": "яБк",
            "focused": "X",
            "default": "X"
        },
        "persistent_workspaces":{
        "1": ["eDP-1"],
        "2": ["eDP-1"],
        "3": ["eDP-1"],
        "4": ["HDMI-A-2"],
        "5": ["HDMI-A-2"],
        "6": ["HDMI-A-2"]
        }
    },
    "sway/mode": {
        "pango_markup": true,
        "format": "{}"
    },
    "sway/window": {
        "format": "{}",
        "max-length": 70, 
        "tooltip": false
    },
    "bluetooth": {
        "interval": 30,
        "format": "{icon}",
        // "format-alt": "{status}",
        "format-icons": {
            "enabled": "яКУ",
            "disabled": "яЪФ"
        },
        "on-click": "blueberry"
    },
    "tray": {
        //"icon-size": 11,
        "spacing": 5
    },
    "clock": {
        "format": "яАЧ  {:%H:%M  яБ│ %e %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>",
        "on-click": "gnome-calendar"
    },
    "network": {
        // "interface": "wlan0", // (Optional) To force the use of this interface,
        "format-wifi": "яЗл  {essid}",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "яЪФ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "family": "ipv4",
        "tooltip-format-wifi": "яЗл  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nяНЧ {bandwidthUpBits} яНФ {bandwidthDownBits}",
        "tooltip-format-ethernet": "яЮЦ {ifname}\nIP: {ipaddr}\nяНЧ {bandwidthUpBits} яНФ {bandwidthDownBits}",
        "on-click-right":"swaymsg exec \\$term_float nmtui"
    },
    "pulseaudio": {
        "scroll-step": 3, // %, can be a float
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        //"format-source": "{volume}% яД░",
        //"format-source-muted": "яД▒",
        "format-source": "яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "swaymsg exec \\$pulseaudio",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
    },
    "custom/weather": {
        "exec": "curl 'https://wttr.in/?format=1'",
        "interval": 3600
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЙБ",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    }
}
